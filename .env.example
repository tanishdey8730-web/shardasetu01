# Sharda Setu — environment configuration
# Copy to .env in project root and restart: npm start

# —— Server ——
PORT=3000
APP_URL=http://localhost:3000

# —— JWT (required in production) ——
JWT_ACCESS_SECRET=change-me-use-long-random-string
JWT_REFRESH_SECRET=change-me-another-long-random-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# —— Google OAuth (optional) ——
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# —— Email / SMTP (optional; dev logs links to console) ——
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Sharda Setu <noreply@yourdomain.com>

# Admin registration bootstrap (optional)
ADMIN_REGISTRATION_SECRET=

# —— Cloudinary (secure cloud storage for images, PDFs, certificates) ——
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# —— PWA push (optional; generate with: npx web-push generate-vapid-keys) ——
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:info@shardasetu.edu

# —— Study Assistant AI ——
CHAT_PROVIDER=auto
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
